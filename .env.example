# ==============================================================================
# RootRecall — Centralized Enterprise Production Environment Configuration Example
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. FRONTEND CONFIGURATION (Next.js / NextAuth)
# ------------------------------------------------------------------------------
# The public canonical URL of your deployed frontend. Defaults to localhost for dev.
NEXTAUTH_URL=http://localhost:3000

# NextAuth secret key used to sign and encrypt session cookies. 
# Generate via: `openssl rand -base64 32`
NEXTAUTH_SECRET=AGrFcQJUSYaqK7Gtjv0VrrsrQ/RqCCZ3q1UXnVmbEiU=

# Public REST API backend endpoint.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Public WebSocket URL for streaming live SRE telemetrics.
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/telemetry


# ------------------------------------------------------------------------------
# 2. BACKEND CONFIGURATION (FastAPI / Uvicorn)
# ------------------------------------------------------------------------------
# FastAPI server listener port.
PORT=8000

# Backend session signing key. Generate via: `openssl rand -hex 32`
SECRET_KEY=6cfbde33e2d70b8f715ac9774c3dde0f7f612e0e9d9817171fe2644e468cad5f
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS allowed origins (comma-separated list for production cors-hardening).
CORS_ORIGINS=http://localhost:3000,https://rootrecall.vercel.app


# ------------------------------------------------------------------------------
# 3. DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# Primary database connection engine.
# - SQLite (Dev): `sqlite:///./rootrecall.db`
# - PostgreSQL (Prod): `postgresql://db_user:db_password@db_host:5432/db_name`
DATABASE_URL=sqlite:///./rootrecall.db


# ------------------------------------------------------------------------------
# 4. AI OBSERVIABILITY PROVIDER (Gemini API)
# ------------------------------------------------------------------------------
# Gemini API Key used by the SRE Orchestrator to generate dynamic incident root causes.
# Get your API key from Google AI Studio.
GEMINI_API_KEY=AIzaSyD-your-gemini-studio-api-key


# ------------------------------------------------------------------------------
# 5. ENTERPRISE OAUTH PROVIDERS
# ------------------------------------------------------------------------------
# Google Cloud Console OAuth 2.0 Credentials (used for Google SSO).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Internal system sync secret to validate incoming OAuth sync requests between frontend and backend.
# Must match between frontend next-auth config and backend request parameters.
INTERNAL_AUTH_SECRET=6cfbde33e2d70b8f715ac9774c3dde0f7f612e0e9d9817171fe2644e468cad5f
